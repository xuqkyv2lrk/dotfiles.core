{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pre-flight.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/post-flight.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__Snyk__snyk_code_scan",
      "mcp__Snyk__snyk_sca_scan",
      "mcp__Snyk__snyk_container_scan",
      "mcp__Snyk__snyk_iac_scan",
      "Bash(runsnyk enable *)",
      "Bash(runsnyk disable *)"
    ]
  },
  "awsAuthRefresh": "aws sts get-caller-identity --profile aws-bedrock 2>/dev/null || aws sso login --profile aws-bedrock"
}
